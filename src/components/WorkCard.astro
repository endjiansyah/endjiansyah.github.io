---
interface Props {
  title: string;
  description: string;
  coverImage: string;
  tools: string[];
  slug: string;
  liveUrl?: string;
}

const { title, description, coverImage, tools, slug, liveUrl } = Astro.props;
---

<a href={`/works/${slug}`} class="reveal reveal-up group block bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl hover:border-brand-dark/20 transition-all duration-300 ease-out hover:-translate-y-1">
  <div class="aspect-video overflow-hidden bg-gray-100">
    <img src={coverImage} alt={title} class="w-full h-full object-cover project-card-img" loading="lazy" />
  </div>
  <div class="p-7">
    <h4 class="text-xl font-semibold mb-2 text-gray-900 group-hover:text-brand-dark transition-colors">{title}</h4>
    <p class="text-gray-500 text-sm leading-relaxed mb-5">
      {description}
    </p>
    <div class="flex gap-2 flex-wrap text-xs font-mono">
      {tools.map((tool) => (
        <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full border border-gray-100">{tool}</span>
      ))}
    </div>
  </div>
</a>
