---
interface Props {
  title: string;
  description: string;
  coverImage: string;
  type: 'mentoring' | 'event' | 'bootcamp' | 'other';
  tags?: string[];
  slug: string;
  date: Date;
  endDate?: Date;
  dateLabel?: string;
}

const { title, description, coverImage, type, tags, slug, date, endDate, dateLabel } = Astro.props;

const typeStyles: Record<string, { bg: string; text: string; label: string }> = {
  mentoring: { bg: 'bg-indigo-50', text: 'text-indigo-600', label: 'Mentoring' },
  event: { bg: 'bg-amber-50', text: 'text-amber-600', label: 'Event' },
  bootcamp: { bg: 'bg-orange-50', text: 'text-orange-600', label: 'Bootcamp' },
  other: { bg: 'bg-teal-50', text: 'text-teal-600', label: 'Lainnya' },
};

const style = typeStyles[type] || typeStyles.other;
---

<a href={`/stories/${slug}`} class="reveal reveal-up group block bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl hover:border-brand-dark/20 transition-all duration-300 ease-out hover:-translate-y-1">
  <div class="h-44 w-full overflow-hidden relative bg-gray-100">
    <img src={coverImage} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent"></div>
    <!-- Type badge on image -->
    <div class="absolute top-4 left-4">
      <span class={`px-3 py-1 text-xs font-semibold rounded-full ${style.bg} ${style.text} border border-current/10`}>
        {style.label}
      </span>
    </div>
    <!-- Title on image -->
    <div class="absolute bottom-4 left-4 right-4">
      <h4 class="text-white text-lg font-semibold leading-tight line-clamp-2">{title}</h4>
    </div>
  </div>

  <div class="p-6">
    <!-- Date display -->
    <div class="flex items-center gap-2 text-xs text-gray-400 mb-3 font-medium uppercase tracking-wider">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      {dateLabel || date.toLocaleDateString('id-ID', { year: 'numeric', month: 'long' })}
    </div>

    <p class="text-gray-500 text-sm leading-relaxed mb-4 line-clamp-3">
      {description}
    </p>
    {tags && tags.length > 0 && (
      <div class="flex gap-2 flex-wrap">
        {tags.map((tag) => (
          <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full text-xs font-medium border border-gray-100">{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>
