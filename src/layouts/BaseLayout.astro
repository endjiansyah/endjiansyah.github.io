---
interface Props {
  title: string;
  description?: string;
  lang?: string;
  ogImage?: string;
}

const { 
  title, 
  description = 'Portfolio Endjiansyah. Berakar dari pengembangan fundamental hingga menakhodai arsitektur sistem berskala enterprise.', 
  lang = 'id',
  ogImage = '/assets/Logokedip.png'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://endjiansyah.github.io');
---

<html lang={lang} class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  
  <!-- Basic SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="Endjiansyah, Endji Ansyah, Software Engineer, Product Manager, Educator, Fullstack Developer, Backend Developer, Programmer Jepara, TALL Stack, Golang, Web Developer Indonesia, Portfolio" />
  <meta name="author" content="Endjiansyah" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalURL.href} />
  
  <!-- Favicon & Icons -->
  <link rel="icon" type="image/png" href="/assets/logo.png" />
  <link rel="apple-touch-icon" href="/assets/logo.png" />
  
  <!-- Open Graph / Social -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`https://endjiansyah.github.io${ogImage}`} />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`https://endjiansyah.github.io${ogImage}`} />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <style>
    body { font-family: 'Inter', system-ui, sans-serif; }
    .glass-nav {
      background: rgba(18, 30, 45, 0.75);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }
    .project-card-img {
      transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .group:hover .project-card-img {
      transform: scale(1.05);
    }
    /* Prose styling for markdown content */
    .prose img {
      border-radius: 1rem;
      margin: 2rem 0;
      width: 100%;
      height: auto;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }
    .prose img + em,
    .prose figcaption {
      display: block;
      text-align: center;
      font-size: 0.875rem;
      color: #9ca3af;
      margin-top: -1rem;
      margin-bottom: 2rem;
    }
    .prose h2 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      color: #111827;
    }
    .prose h3 {
      font-size: 1.25rem;
      font-weight: 600;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      color: #1f2937;
    }
    .prose p {
      margin-bottom: 1.25rem;
      line-height: 1.8;
      color: #4b5563;
    }
    .prose ul, .prose ol {
      margin-bottom: 1.25rem;
      padding-left: 1.5rem;
      color: #4b5563;
    }
    .prose li {
      margin-bottom: 0.5rem;
      line-height: 1.7;
    }
    .prose blockquote {
      border-left: 3px solid #121E2D;
      padding-left: 1rem;
      margin: 1.5rem 0;
      font-style: italic;
      color: #6b7280;
    }
    .prose code {
      background: #f3f4f6;
      padding: 0.15rem 0.4rem;
      border-radius: 0.25rem;
      font-size: 0.875em;
    }
    .prose pre {
      background: #1f2937;
      color: #e5e7eb;
      padding: 1.25rem;
      border-radius: 0.75rem;
      overflow-x: auto;
      margin: 1.5rem 0;
    }
    .prose pre code {
      background: none;
      padding: 0;
      color: inherit;
    }
    .prose a {
      color: #121E2D;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .prose a:hover {
      color: #3b82f6;
    }
  </style>
</head>
<body class="bg-[#F8F9FA] text-gray-800 antialiased selection:bg-brand-dark selection:text-white">

  <slot name="nav" />
  <slot />
  <slot name="footer" />

</body>
</html>
