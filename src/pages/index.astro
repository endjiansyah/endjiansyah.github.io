---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WorkCard from '../components/WorkCard.astro';
import StoryCard from '../components/StoryCard.astro';
import { getCollection } from 'astro:content';

// Fetch content collections
const allWorks = (await getCollection('works')).sort((a, b) => a.data.order - b.data.order);
const allStories = (await getCollection('stories')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Endjiansyah - Software Engineer, Product Manager & Educator">
  <Navbar slot="nav" />

  <!-- ======================== -->
  <!-- Hero Section             -->
  <!-- ======================== -->
  <section id="hero" class="relative bg-brand-dark text-white min-h-[90vh] flex items-center px-6 sm:px-12 md:px-20 overflow-hidden">
    <!-- Subtle background gradient blobs -->
    <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-blue-500/5 rounded-full blur-[120px] -translate-y-1/3 translate-x-1/4"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-teal-500/5 rounded-full blur-[100px] translate-y-1/3 -translate-x-1/4"></div>
    
    <div class="max-w-5xl mx-auto relative z-10 flex flex-col md:flex-row justify-between items-center gap-12 md:gap-20 py-32 w-full">
      <div class="flex-1 text-center md:text-left">
        <h1 class="text-5xl md:text-7xl font-semibold tracking-tight mb-4 leading-[1.1]">
          Endjiansyah<span class="text-blue-400">.</span>
        </h1>
        <h2 class="text-lg md:text-xl text-gray-400 font-light tracking-wide mb-8 leading-relaxed">
          Software Engineer &bull; Product Manager &bull; Educator
        </h2>
        <p class="text-base md:text-lg leading-relaxed text-gray-500 max-w-xl mx-auto md:mx-0 font-light">
          Berakar dari pengembangan fundamental hingga menakhodai arsitektur sistem berskala enterprise. Memposisikan diri di titik tengah antara rekayasa teknis perangkat lunak, penyelarasan visi produk, dan komitmen kuat pada edukasi berbasis inklusi.
        </p>
        
        <div class="mt-10 flex flex-wrap gap-3 text-sm font-medium justify-center md:justify-start">
          <a href="https://github.com/endjiansyah" target="_blank" rel="noopener noreferrer" class="px-6 py-2.5 bg-white text-brand-dark rounded-full hover:bg-gray-100 transition-colors shadow-sm">GitHub</a>
          <a href="https://www.linkedin.com/in/endji-ansyah-30322a115/" target="_blank" rel="noopener noreferrer" class="px-6 py-2.5 border border-white/20 rounded-full hover:bg-white/10 transition-colors">LinkedIn</a>
          <a href="https://wa.me/6285800583260" target="_blank" rel="noopener noreferrer" class="px-6 py-2.5 border border-white/20 rounded-full hover:bg-white/10 transition-colors">WhatsApp</a>
          <a href="mailto:endji1507@gmail.com" class="px-6 py-2.5 border border-white/20 rounded-full hover:bg-white/10 transition-colors">Email</a>
        </div>
      </div>
      
      <!-- Photo Avatar -->
      <div class="flex-shrink-0 order-first md:order-last">
        <div class="relative group">
          <div class="absolute -inset-2 bg-blue-400/15 rounded-full blur-xl opacity-0 group-hover:opacity-100 transition duration-700"></div>
          <img src="/assets/profile.png" alt="Endjiansyah" class="relative w-52 h-52 lg:w-72 lg:h-72 object-cover rounded-full grayscale hover:grayscale-0 border-4 border-white/10 shadow-2xl transition-all duration-500 hover:border-blue-400/30 z-10" />
        </div>
      </div>

    </div>
  </section>

  <!-- ======================== -->
  <!-- Section: The Journey     -->
  <!-- ======================== -->
  <section id="journey" class="py-24 sm:py-32 bg-[#F8F9FA]">
    <div class="max-w-6xl mx-auto px-6 sm:px-12 md:px-20 relative">
      <div class="mb-16 flex items-baseline gap-4">
        <h3 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight">The Journey</h3>
        <span class="h-px bg-gray-300 flex-1 ml-4 hidden md:block"></span>
      </div>

      <!-- Split Grid Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        
        <!-- Column 1: Pengalaman Kerja -->
        <div>
          <div class="flex items-center gap-4 mb-10">
            <div class="w-10 h-10 rounded-xl bg-brand-dark/10 flex items-center justify-center text-brand-dark">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <h4 class="text-2xl font-bold text-gray-900 tracking-tight">Pengalaman Kerja</h4>
          </div>

          <div class="relative border-l-2 border-gray-200 ml-5 space-y-14 py-2">
            
            <!-- Node: PM/EM -->
            <div class="relative pl-10 md:pl-12 group">
              <div class="absolute -left-[11px] top-1.5 w-5 h-5 bg-brand-dark border-4 border-brand-dark rounded-full shadow-md group-hover:scale-125 transition-transform"></div>
              <div class="text-xs font-semibold text-brand-dark mb-1 tracking-widest uppercase">2024 — Present</div>
              <h4 class="text-xl font-semibold text-gray-900 mb-1.5">Product Manager / Engineering Manager</h4>
              <span class="inline-block px-3 py-0.5 bg-brand-dark/5 text-brand-dark font-medium text-xs mb-3 rounded-full border border-brand-dark/10">Alkademi / inideku.id</span>
              <p class="text-gray-500 leading-relaxed text-sm">
                Beralih peran menuju kepemimpinan produk dan manajemen rekayasa. Memastikan penyelarasan visi antara pengembangan teknis, roadmap produk, dan pengiriman solusi tepat sasaran.
              </p>
            </div>

            <!-- Node: Web Dev -->
            <div class="relative pl-10 md:pl-12 group">
              <div class="absolute -left-[11px] top-1.5 w-5 h-5 bg-white border-[3px] border-gray-300 rounded-full group-hover:border-brand-dark group-hover:scale-125 transition-all"></div>
              <div class="text-xs font-semibold text-gray-400 mb-1 tracking-widest uppercase">Jul 2023 — 2024</div>
              <h4 class="text-xl font-semibold text-gray-900 mb-1.5">Web Developer</h4>
              <span class="inline-block px-3 py-0.5 bg-white border border-gray-200 text-gray-600 font-medium text-xs mb-3 rounded-full">inideku.id & Freelance</span>
              <p class="text-gray-500 leading-relaxed text-sm">
                Merancang, mengembangkan, dan memelihara aplikasi web. Mengoptimalkan utilitas TALL Stack secara efisien hingga implementasi integrasi ReactJS.
              </p>
            </div>

            <!-- Node: Backend -->
            <div class="relative pl-10 md:pl-12 group">
              <div class="absolute -left-[11px] top-1.5 w-5 h-5 bg-white border-[3px] border-gray-300 rounded-full group-hover:border-brand-dark group-hover:scale-125 transition-all"></div>
              <div class="text-xs font-semibold text-gray-400 mb-1 tracking-widest uppercase">Mar 2023 — Jul 2023</div>
              <h4 class="text-xl font-semibold text-gray-900 mb-1.5">Backend Developer</h4>
              <span class="inline-block px-3 py-0.5 bg-white border border-gray-200 text-gray-600 font-medium text-xs mb-3 rounded-full">CODELITE</span>
              <p class="text-gray-500 leading-relaxed text-sm">
                Rekayasa server-side menggunakan bahasa Go (Golang). Mensirkulasi komputasi backend yang stabil untuk mendukung optimasi dan reliabilitas tinggi aplikasi.
              </p>
            </div>

            <!-- Node: Web Dev (Early) -->
            <div class="relative pl-10 md:pl-12 group">
              <div class="absolute -left-[11px] top-1.5 w-5 h-5 bg-white border-[3px] border-gray-300 rounded-full group-hover:border-gray-500 group-hover:scale-125 transition-all"></div>
              <div class="text-xs font-semibold text-gray-400 mb-1 tracking-widest uppercase">Dec 2020 — Oct 2022</div>
              <h4 class="text-xl font-semibold text-gray-900 mb-1.5">Freelance Web Developer</h4>
              <span class="inline-block px-3 py-0.5 bg-white border border-gray-200 text-gray-600 font-medium text-xs mb-3 rounded-full">inideku.id & Local Clients</span>
              <p class="text-gray-500 leading-relaxed text-sm">
                Mengerjakan ragam kustomisasi sistem dan purwarupa web (monolith) berbasis MVC secara lepas menggunakan bahasa pemrograman PHP, Codeigniter 3, dan Bootstrap.
              </p>
            </div>

            <!-- Node: Internship -->
            <div class="relative pl-10 md:pl-12 group">
              <div class="absolute -left-[11px] top-1.5 w-5 h-5 bg-white border-[3px] border-gray-300 rounded-full group-hover:border-gray-500 group-hover:scale-125 transition-all"></div>
              <div class="text-xs font-semibold text-gray-400 mb-1 tracking-widest uppercase">Dec 2019 — Feb 2020</div>
              <h4 class="text-xl font-semibold text-gray-900 mb-1.5">Praktek Kerja Lapangan</h4>
              <span class="inline-block px-3 py-0.5 bg-white border border-gray-200 text-gray-600 font-medium text-xs mb-3 rounded-full">Diskominfo Kab. Jepara</span>
              <p class="text-gray-500 leading-relaxed text-sm">
                Menyelami ekosistem karir profesional secara nyata. Merakit WBS Jepara yang memfasilitasi pelaporan terukur Pemda dalam wujud _fullstack application_ pertama saya.
              </p>
            </div>

            <!-- Node: School Operator -->
            <div class="relative pl-10 md:pl-12 group">
              <div class="absolute -left-[11px] top-1.5 w-5 h-5 bg-white border-[3px] border-gray-200 rounded-full group-hover:border-gray-400 group-hover:scale-125 transition-all"></div>
              <div class="text-xs font-semibold text-gray-400 mb-1 tracking-widest uppercase">Dec 2018 — Jun 2019</div>
              <h4 class="text-xl font-semibold text-gray-900 mb-1.5">Operator Sekolah</h4>
              <span class="inline-block px-3 py-0.5 bg-white border border-gray-200 text-gray-600 font-medium text-xs mb-3 rounded-full">SMK MIS Jabal Nur</span>
              <p class="text-gray-500 leading-relaxed text-sm">
                Rekam jejak dasar dalam mengelola administrasi tersistem dan data teknis kependidikan di lingkungan sekolah menengah secara presisi.
              </p>
            </div>

          </div>
        </div>

        <!-- Column 2: Pendidikan & Pelatihan -->
        <div>
          <div class="flex items-center gap-4 mb-10">
            <div class="w-10 h-10 rounded-xl bg-orange-100 flex items-center justify-center text-orange-600">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14v7"></path></svg>
            </div>
            <h4 class="text-2xl font-bold text-gray-900 tracking-tight">Pendidikan & Pelatihan</h4>
          </div>

          <div class="relative border-l-2 border-gray-200 ml-5 space-y-14 py-2">
            
            <!-- Node: Bootcamp -->
            <div class="relative pl-10 md:pl-12 group">
              <div class="absolute -left-[11px] top-1.5 w-5 h-5 bg-white border-[3px] border-orange-300 rounded-full group-hover:border-orange-500 group-hover:scale-125 transition-all"></div>
              <div class="text-xs font-semibold text-gray-400 mb-1 tracking-widest uppercase">Nov 2022 — Jan 2023</div>
              <h4 class="text-xl font-semibold text-gray-900 mb-1.5">Bootcamp Scholarship</h4>
              <span class="inline-block px-3 py-0.5 bg-orange-50 text-orange-600 font-medium text-xs mb-3 rounded-full border border-orange-100">Alkademi — UMPTN Farcapital</span>
              <p class="text-gray-500 leading-relaxed text-sm">
                Menempuh pelatihan vokasi intensif *on-site* di Bandung. Memperdalam praktik dan pemahaman fundamental _software architecture_ Laravel modern dan kolaborasi tim.
              </p>
            </div>

            <!-- Node: College -->
            <div class="relative pl-10 md:pl-12 group">
              <div class="absolute -left-[11px] top-1.5 w-5 h-5 bg-white border-[3px] border-gray-200 rounded-full group-hover:border-gray-400 group-hover:scale-125 transition-all"></div>
              <div class="text-xs font-semibold text-gray-400 mb-1 tracking-widest uppercase">2018 — 2020</div>
              <h4 class="text-xl font-semibold text-gray-800 mb-1.5">Pendidikan D2</h4>
              <span class="inline-block px-3 py-0.5 bg-gray-100 text-gray-500 font-medium text-xs mb-3 rounded-full">Politeknik Negeri Malang</span>
              <p class="text-gray-400 leading-relaxed text-sm">
                Diploma Manajemen Informatika. Memperoleh fondasi baku logika pemrograman, pengelolaan basis data, algoritma, dan praktik awal manajemen proyek rekayasa perangkat lunak.
              </p>
            </div>

            <!-- Node: High School -->
            <div class="relative pl-10 md:pl-12 group">
              <div class="absolute -left-[11px] top-1.5 w-5 h-5 bg-white border-[3px] border-gray-200 rounded-full group-hover:border-gray-400 group-hover:scale-125 transition-all"></div>
              <div class="text-xs font-semibold text-gray-400 mb-1 tracking-widest uppercase">2015 — 2018</div>
              <h4 class="text-xl font-semibold text-gray-800 mb-1.5">SMK Negeri 3 Jepara</h4>
              <span class="inline-block px-3 py-0.5 bg-gray-100 text-gray-500 font-medium text-xs mb-3 rounded-full">Teknik Komputer & Jaringan</span>
              <p class="text-gray-400 leading-relaxed text-sm">
                Pendidikan vokasi jenjang menengah yang berfokus pada pemahaman fundamental infrastruktur TI, arsitektur *hardware*, logik topologi jaringan, dan administrasi server linux.
              </p>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ======================== -->
  <!-- Section: Works           -->
  <!-- ======================== -->
  <section id="works" class="py-24 sm:py-32 bg-white border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-6 sm:px-12 md:px-20">
      <div class="mb-14 flex items-baseline gap-4">
        <h3 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight">Selected Works</h3>
        <span class="h-px bg-gray-300 flex-1 ml-4 hidden sm:block"></span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {allWorks.map((work) => (
          <WorkCard
            title={work.data.title}
            description={work.data.description}
            coverImage={work.data.coverImage}
            tools={work.data.tools}
            slug={work.slug}
            liveUrl={work.data.liveUrl}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ======================== -->
  <!-- Section: Stories         -->
  <!-- ======================== -->
  <section id="stories" class="py-24 sm:py-32 bg-[#F8F9FA]">
    <div class="max-w-6xl mx-auto px-6 sm:px-12 md:px-20">
      <div class="mb-12">
        <div class="flex items-baseline gap-4 mb-5">
          <h3 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight">Stories & Initiatives</h3>
          <span class="h-px bg-gray-300 flex-1 ml-4 hidden sm:block"></span>
        </div>
        <p class="text-gray-500 text-base md:text-lg max-w-3xl leading-relaxed">
          Berikut adalah sorotan eksklusif dari beberapa inisiatif pengajaran dan program pengembangan pilihan. Kurasi ini menampilkan rekam jejak mentorship yang paling berdampak dalam membagikan ekosistem teknologi di komunitas.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {allStories.map((story) => (
          <StoryCard
            title={story.data.title}
            description={story.data.description}
            coverImage={story.data.coverImage}
            type={story.data.type}
            tags={story.data.tags}
            slug={story.slug}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ======================== -->
  <!-- Section: Contact CTA     -->
  <!-- ======================== -->
  <section id="contact" class="py-20 bg-brand-dark text-white relative overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-blue-500/5 rounded-full blur-[100px]"></div>
    <div class="max-w-3xl mx-auto px-6 sm:px-12 md:px-20 text-center relative z-10">
      <h3 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Mari Berkolaborasi</h3>
      <p class="text-gray-400 text-base md:text-lg leading-relaxed mb-10 max-w-xl mx-auto font-light">
        Punya ide proyek, peluang kolaborasi, atau sekadar ingin berdiskusi? Saya selalu terbuka untuk koneksi baru.
      </p>
      <div class="flex flex-wrap gap-4 justify-center text-sm font-medium">
        <a href="mailto:endji1507@gmail.com" class="px-8 py-3 bg-white text-brand-dark rounded-full hover:bg-gray-100 transition-colors shadow-sm">Kirim Email</a>
        <a href="https://wa.me/6285800583260" target="_blank" rel="noopener noreferrer" class="px-8 py-3 border border-white/20 rounded-full hover:bg-white/10 transition-colors">WhatsApp</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
