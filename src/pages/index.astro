// PANDUAN PENGISIAN DATA MENTORING & PORTFOLIO TAMBAHAN
// 1. Tambahkan atau ubah data di bawah ini.
// 2. Ganti link `image` ke lokasi file gambar Anda di folder public/assets/img/ (misalnya: '/assets/img/foto.jpg')
// 3. Tulis detail panjang di `fullStory`.
const mentoringItems = [
  {
    id: 'placeholder-1',
    title: 'Judul Mentoring / Inisiatif',
    shortDesc: 'Tuliskan deskripsi singkat mengenai apa yang Anda lakukan atau ajarkan pada program ini.',
    fullStory: 'Ketik cerita dan detail lengkap dokumentasi Anda di sini. Jelaskan latar belakang, tantangan, dan impact yang dihasilkan.',
    tag: 'Kategori (e.g. Edukasi)',
    image: 'https://images.unsplash.com/photo-1542744173-8e7e53415bb0?q=80&w=600&auto=format&fit=crop', // Ganti dengan path gambar Anda
    iconBg: 'bg-indigo-100',
    iconText: 'text-indigo-600',
    iconPath: 'M13 10V3L4 14h7v7l9-11h-7z'
  },
  {
    id: 'placeholder-2',
    title: 'Program / Workshop Pilihan',
    shortDesc: 'Penjelasan singkat acara atau aktivitas yang berjalan.',
    fullStory: 'Jabarkan proses dan teknis pelaksanaannya di sini sebagai studi kasus portfolio Anda.',
    tag: 'Kategori (e.g. Workshop)',
    image: 'https://images.unsplash.com/photo-1516321497487-e288fb19713f?q=80&w=600&auto=format&fit=crop', // Ganti dengan path gambar Anda
    iconBg: 'bg-orange-100',
    iconText: 'text-orange-600',
    iconPath: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z'
  }
  // Copy-paste blok di atas untuk menambahkan lebih banyak kartu.
];
---

<html lang="id" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  
  <!-- Basic SEO -->
  <title>Endjiansyah - Software Engineer, Product Manager & Educator</title>
  <meta name="description" content="Portfolio Endjiansyah. Berakar dari pengembangan fundamental hingga menakhodai arsitektur sistem berskala enterprise. Rekayasa teknis, visi produk, dan edukasi inklusi." />
  <meta name="keywords" content="Endjiansyah, Endji Ansyah, Software Engineer, Product Manager, Educator, Fullstack Developer, Backend Developer, Programmer Jepara, TALL Stack, Golang, Web Developer Indonesia, Portfolio" />
  <meta name="author" content="Endjiansyah" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://endjiansyah.github.io/" />
  
  <!-- Favicon & Icons -->
  <link rel="icon" type="image/png" href="/assets/logo.png" />
  <link rel="apple-touch-icon" href="/assets/logo.png" />
  
  <!-- Open Graph / Social -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://endjiansyah.github.io/" />
  <meta property="og:title" content="Endjiansyah - Software Engineer Portfolio" />
  <meta property="og:description" content="Menjembatani eksekusi teknis perangkat lunak. Cek ragam pengalaman industri dan portfolio teknis saya." />
  <meta property="og:image" content="https://endjiansyah.github.io/assets/Logokedip.png" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Endjiansyah - Software Engineer Portfolio" />
  <meta name="twitter:description" content="Menjembatani eksekusi teknis perangkat lunak. Cek ragam pengalaman industri dan portfolio teknis saya." />
  <meta name="twitter:image" content="https://endjiansyah.github.io/assets/Logokedip.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', system-ui, sans-serif; }
    .glass-nav {
      background: rgba(18, 30, 45, 0.75);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }
    .project-card-img {
      transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .group:hover .project-card-img {
      transform: scale(1.05);
    }
  </style>
</head>
<body class="bg-[#F8F9FA] text-gray-800 antialiased selection:bg-brand-dark selection:text-white">

  <!-- ======================== -->
  <!-- Floating Navigation      -->
  <!-- ======================== -->
  <nav class="fixed top-5 left-0 right-0 z-50 px-4 pointer-events-none">
    <div class="max-w-max mx-auto glass-nav border border-white/10 shadow-lg rounded-full pointer-events-auto px-5 py-2.5 flex items-center gap-6 text-sm font-medium tracking-wide text-gray-300">
      <a href="#hero" class="block h-9 w-9 hover:scale-110 transition-transform flex-shrink-0 rounded-full overflow-hidden border border-white/20">
        <img src="/assets/logo.png" alt="End Projects" class="h-full w-full object-cover" />
      </a>
      <div class="h-4 w-px bg-white/20"></div>
      <a href="#works" class="hover:text-white transition-colors">Works</a>
      <a href="#journey" class="hover:text-white transition-colors">Journey</a>
      <a href="#contact" class="hover:text-white transition-colors">Contact</a>
    </div>
  </nav>

  <!-- ======================== -->
  <!-- Hero Section             -->
  <!-- ======================== -->
  <section id="hero" class="relative bg-brand-dark text-white min-h-[90vh] flex items-center px-6 sm:px-12 md:px-20 overflow-hidden">
    <!-- Subtle background gradient blobs -->
    <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-blue-500/5 rounded-full blur-[120px] -translate-y-1/3 translate-x-1/4"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-teal-500/5 rounded-full blur-[100px] translate-y-1/3 -translate-x-1/4"></div>
    
    <div class="max-w-5xl mx-auto relative z-10 flex flex-col md:flex-row justify-between items-center gap-12 md:gap-20 py-32 w-full">
      <div class="flex-1 text-center md:text-left">
        <h1 class="text-5xl md:text-7xl font-semibold tracking-tight mb-4 leading-[1.1]">
          Endjiansyah<span class="text-blue-400">.</span>
        </h1>
        <h2 class="text-lg md:text-xl text-gray-400 font-light tracking-wide mb-8 leading-relaxed">
          Software Engineer &bull; Product Manager &bull; Educator
        </h2>
        <p class="text-base md:text-lg leading-relaxed text-gray-500 max-w-xl mx-auto md:mx-0 font-light">
          Berakar dari pengembangan fundamental hingga menakhodai arsitektur sistem berskala enterprise. Memposisikan diri di titik tengah antara rekayasa teknis perangkat lunak, penyelarasan visi produk, dan komitmen kuat pada edukasi berbasis inklusi.
        </p>
        
        <div class="mt-10 flex flex-wrap gap-3 text-sm font-medium justify-center md:justify-start">
          <a href="https://github.com/endjiansyah" target="_blank" rel="noopener noreferrer" class="px-6 py-2.5 bg-white text-brand-dark rounded-full hover:bg-gray-100 transition-colors shadow-sm">GitHub</a>
          <a href="https://www.linkedin.com/in/endji-ansyah-30322a115/" target="_blank" rel="noopener noreferrer" class="px-6 py-2.5 border border-white/20 rounded-full hover:bg-white/10 transition-colors">LinkedIn</a>
          <a href="https://wa.me/6285800583260" target="_blank" rel="noopener noreferrer" class="px-6 py-2.5 border border-white/20 rounded-full hover:bg-white/10 transition-colors">WhatsApp</a>
          <a href="mailto:endji1507@gmail.com" class="px-6 py-2.5 border border-white/20 rounded-full hover:bg-white/10 transition-colors">Email</a>
        </div>
      </div>
      
      <!-- Photo Avatar -->
      <div class="flex-shrink-0 order-first md:order-last">
        <div class="relative group">
          <div class="absolute -inset-2 bg-blue-400/15 rounded-full blur-xl opacity-0 group-hover:opacity-100 transition duration-700"></div>
          <img src="/assets/profile.png" alt="Endjiansyah" class="relative w-52 h-52 lg:w-72 lg:h-72 object-cover rounded-full grayscale hover:grayscale-0 border-4 border-white/10 shadow-2xl transition-all duration-500 hover:border-blue-400/30 z-10" />
        </div>
      </div>

    </div>
  </section>

  <!-- ======================== -->
  <!-- Section: Works           -->
  <!-- ======================== -->
  <section id="works" class="py-24 sm:py-32 bg-[#F8F9FA]">
    <div class="max-w-6xl mx-auto px-6 sm:px-12 md:px-20">
      <div class="mb-14 flex items-baseline gap-4">
        <h3 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight">Selected Works</h3>
        <span class="h-px bg-gray-300 flex-1 ml-4 hidden sm:block"></span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        
        <!-- Project 1: WBS Jepara -->
        <a href="http://wbs.jepara.go.id" target="_blank" rel="noopener noreferrer" class="group block bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl hover:border-brand-dark/20 transition-all duration-300 ease-out hover:-translate-y-1">
          <div class="aspect-video overflow-hidden bg-gray-100">
            <img src="/assets/img/wbs.png" alt="Whistleblowing System Jepara" class="w-full h-full object-cover project-card-img" />
          </div>
          <div class="p-7">
            <h4 class="text-xl font-semibold mb-2 text-gray-900 group-hover:text-brand-dark transition-colors">Whistleblowing System Jepara</h4>
            <p class="text-gray-500 text-sm leading-relaxed mb-5">
              Sistem pelaporan terintegrasi pertama untuk Pemerintah Daerah Kabupaten Jepara. Project fullstack pertama yang masih digunakan hingga saat ini.
            </p>
            <div class="flex gap-2 flex-wrap text-xs font-mono">
              <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full border border-gray-100">Codeigniter_3</span>
              <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full border border-gray-100">Bootstrap</span>
              <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full border border-gray-100">Fullstack</span>
            </div>
          </div>
        </a>

        <!-- Project 2: SMA Negeri 1 Jepara (New) -->
        <a href="https://sman1jepara.sch.id" target="_blank" rel="noopener noreferrer" class="group block bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl hover:border-brand-dark/20 transition-all duration-300 ease-out hover:-translate-y-1">
          <div class="aspect-video overflow-hidden bg-gray-100">
            <img src="/assets/img/smansara.png" alt="SMA Negeri 1 Jepara Website" class="w-full h-full object-cover project-card-img" />
          </div>
          <div class="p-7">
            <h4 class="text-xl font-semibold mb-2 text-gray-900 group-hover:text-brand-dark transition-colors">SMA Negeri 1 Jepara</h4>
            <p class="text-gray-500 text-sm leading-relaxed mb-5">
              Revitalisasi platform akademik utama sekolah negeri menggunakan TALL Stack. Dibangun ulang dari Codeigniter ke arsitektur modern sejak September 2023.
            </p>
            <div class="flex gap-2 flex-wrap text-xs font-mono">
              <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full border border-gray-100">Laravel</span>
              <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full border border-gray-100">Tailwind_CSS</span>
              <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full border border-gray-100">Livewire</span>
            </div>
          </div>
        </a>

        <!-- Project 3: ArcticVIP -->
        <a href="https://illustrious-parfait-a6f428.netlify.app/" target="_blank" rel="noopener noreferrer" class="group block bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl hover:border-brand-dark/20 transition-all duration-300 ease-out hover:-translate-y-1">
          <div class="aspect-video overflow-hidden bg-gray-100">
            <img src="/assets/img/arcticvip.png" alt="ArcticVIP Redesign" class="w-full h-full object-cover project-card-img" />
          </div>
          <div class="p-7">
            <h4 class="text-xl font-semibold mb-2 text-gray-900 group-hover:text-brand-dark transition-colors">ArcticVIP Redesign</h4>
            <p class="text-gray-500 text-sm leading-relaxed mb-5">
              Re-engineering visual dari mock-up desain contest freelance menjadi kode yang akurat, responsif, dan pixel-perfect.
            </p>
            <div class="flex gap-2 flex-wrap text-xs font-mono">
              <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full border border-gray-100">Tailwind_CSS</span>
              <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full border border-gray-100">Frontend</span>
            </div>
          </div>
        </a>

        <!-- Project 4: GeKAES -->
        <div class="group block bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl hover:border-brand-dark/20 transition-all duration-300 ease-out hover:-translate-y-1">
          <div class="aspect-video overflow-hidden bg-gray-100">
            <img src="/assets/img/gekaes.png" alt="GeKAES SMAN 1 Jepara" class="w-full h-full object-cover project-card-img" />
          </div>
          <div class="p-7">
            <h4 class="text-xl font-semibold mb-2 text-gray-900 group-hover:text-brand-dark transition-colors">GeKAES SMA N 1 Jepara</h4>
            <p class="text-gray-500 text-sm leading-relaxed mb-5">
              Website event GeKAES XXV & XXVI (2021–2022) untuk SMA Negeri 1 Jepara. Mengelola informasi kegiatan dan registrasi peserta secara digital.
            </p>
            <div class="flex gap-2 flex-wrap text-xs font-mono">
              <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full border border-gray-100">Codeigniter_3</span>
              <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full border border-gray-100">Bootstrap</span>
            </div>
          </div>
        </div>

        <!-- Project 5: EndProjects Portfolio -->
        <div class="group block bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl hover:border-brand-dark/20 transition-all duration-300 ease-out hover:-translate-y-1">
          <div class="aspect-video overflow-hidden bg-gray-100">
            <img src="/assets/img/endproject.png" alt="EndProjects Portfolio" class="w-full h-full object-cover project-card-img" />
          </div>
          <div class="p-7">
            <h4 class="text-xl font-semibold mb-2 text-gray-900 group-hover:text-brand-dark transition-colors">EndProjects; Portfolio</h4>
            <p class="text-gray-500 text-sm leading-relaxed mb-5">
              Iterasi web portfolio personal. Migrasi dari Bootstrap konvensional menuju ekosistem Tailwind CSS dengan switch bahasa menggunakan Alpine JS.
            </p>
            <div class="flex gap-2 flex-wrap text-xs font-mono">
              <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full border border-gray-100">Tailwind_CSS</span>
              <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full border border-gray-100">Alpine_JS</span>
            </div>
          </div>
        </div>

        <!-- Project 6: SMA N 1 Jepara (Old) -->
        <div class="group block bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl hover:border-brand-dark/20 transition-all duration-300 ease-out hover:-translate-y-1">
          <div class="aspect-video overflow-hidden bg-gray-100">
            <img src="/assets/img/sman1jepara.png" alt="SMA Negeri 1 Jepara versi lama" class="w-full h-full object-cover project-card-img" />
          </div>
          <div class="p-7">
            <h4 class="text-xl font-semibold mb-2 text-gray-900 group-hover:text-brand-dark transition-colors">SMA N 1 Jepara (v1)</h4>
            <p class="text-gray-500 text-sm leading-relaxed mb-5">
              Versi awal website SMA Negeri 1 Jepara yang dibangun pada Juni 2021. Menjadi fondasi sebelum dimigrasi ke arsitektur TALL Stack.
            </p>
            <div class="flex gap-2 flex-wrap text-xs font-mono">
              <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full border border-gray-100">Codeigniter_3</span>
              <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full border border-gray-100">Bootstrap</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ======================== -->
  <!-- Section: Mentoring & PM  -->
  <!-- ======================== -->
  <section id="mentoring" class="py-24 sm:py-32 bg-white border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-6 sm:px-12 md:px-20">
      <div class="mb-12">
        <div class="flex items-baseline gap-4 mb-5">
          <h3 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight">Mentoring & Initiatives</h3>
          <span class="h-px bg-gray-300 flex-1 ml-4 hidden sm:block"></span>
        </div>
        <p class="text-gray-500 text-base md:text-lg max-w-3xl leading-relaxed">
          Berikut adalah sorotan eksklusif dari beberapa inisiatif pengajaran dan program pengembangan pilihan. Kurasi ini menampilkan rekam jejak mentorship yang paling berdampak dalam membagikan ekosistem teknologi di komunitas.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        {mentoringItems.map((item) => (
          <div>
            <!-- Card -->
            <div 
              class="bg-white rounded-2xl overflow-hidden border border-gray-100 hover:border-brand-dark/20 shadow-sm hover:shadow-xl transition-all duration-300 group cursor-pointer flex flex-col h-full"
              onclick={`document.getElementById('modal-${item.id}').showModal()`}
            >
              <!-- Image Banner Placeholder -->
              <div class="h-40 w-full overflow-hidden relative bg-gray-100 shrink-0">
                <img src={item.image} alt={item.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                <!-- Gradient overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent"></div>
                <div class="absolute bottom-4 left-4 flex gap-2 items-center text-white">
                  <div class={`w-8 h-8 rounded shrink-0 flex items-center justify-center ${item.iconBg} ${item.iconText}`}>
                     <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.iconPath}></path></svg>
                  </div>
                  <h4 class="text-base font-semibold truncate pr-2 leading-tight">{item.title}</h4>
                </div>
              </div>

              <!-- Card Content -->
              <div class="p-6 flex-1 flex flex-col justify-between">
                <p class="text-gray-500 text-sm leading-relaxed mb-4 line-clamp-3">
                  {item.shortDesc}
                </p>
                <div>
                  <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-full text-xs font-medium border border-gray-100">{item.tag}</span>
                </div>
              </div>
            </div>

            <!-- Modal Pop-Up Dialog Native HTML -->
            <dialog id={`modal-${item.id}`} class="p-0 rounded-2xl shadow-2xl backdrop:bg-black/60 overflow-hidden w-[95%] max-w-2xl bg-white m-auto fixed inset-0 z-[100]">
              <div class="relative max-h-[85vh] flex flex-col">
                
                <!-- Close Button -->
                <button 
                  onclick={`document.getElementById('modal-${item.id}').close()`} 
                  class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center bg-black/40 text-white rounded-full hover:bg-black/70 z-10 transition-colors backdrop-blur-sm"
                >&times;</button>
                
                <!-- Expanded Image -->
                <div class="h-56 sm:h-72 w-full shrink-0">
                   <img src={item.image} class="w-full h-full object-cover" alt={item.title} />
                </div>
                
                <!-- Full Story / Content -->
                <div class="p-6 sm:p-10 overflow-y-auto">
                   <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">{item.title}</h2>
                   <span class="inline-block px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium mb-6">{item.tag}</span>
                   
                   <div class="prose prose-sm sm:prose-base text-gray-600 leading-relaxed">
                      <p>{item.fullStory}</p>
                   </div>
                </div>

              </div>
            </dialog>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- ======================== -->
  <!-- Section: The Journey     -->
  <!-- ======================== -->
  <section id="journey" class="py-24 sm:py-32 bg-[#F8F9FA]">
    <div class="max-w-6xl mx-auto px-6 sm:px-12 md:px-20 relative">
      <div class="mb-16 flex items-baseline gap-4">
        <h3 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight">The Journey</h3>
        <span class="h-px bg-gray-300 flex-1 ml-4 hidden md:block"></span>
      </div>

      <!-- Split Grid Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        
        <!-- Column 1: Pengalaman Kerja -->
        <div>
          <div class="flex items-center gap-4 mb-10">
            <div class="w-10 h-10 rounded-xl bg-brand-dark/10 flex items-center justify-center text-brand-dark">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <h4 class="text-2xl font-bold text-gray-900 tracking-tight">Pengalaman Kerja</h4>
          </div>

          <div class="relative border-l-2 border-gray-200 ml-5 space-y-14 py-2">
            
            <!-- Node: PM/EM -->
            <div class="relative pl-10 md:pl-12 group">
              <div class="absolute -left-[11px] top-1.5 w-5 h-5 bg-brand-dark border-4 border-brand-dark rounded-full shadow-md group-hover:scale-125 transition-transform"></div>
              <div class="text-xs font-semibold text-brand-dark mb-1 tracking-widest uppercase">2024 — Present</div>
              <h4 class="text-xl font-semibold text-gray-900 mb-1.5">Product Manager / Engineering Manager</h4>
              <span class="inline-block px-3 py-0.5 bg-brand-dark/5 text-brand-dark font-medium text-xs mb-3 rounded-full border border-brand-dark/10">Alkademi / inideku.id</span>
              <p class="text-gray-500 leading-relaxed text-sm">
                Beralih peran menuju kepemimpinan produk dan manajemen rekayasa. Memastikan penyelarasan visi antara pengembangan teknis, roadmap produk, dan pengiriman solusi tepat sasaran.
              </p>
            </div>

            <!-- Node: Web Dev -->
            <div class="relative pl-10 md:pl-12 group">
              <div class="absolute -left-[11px] top-1.5 w-5 h-5 bg-white border-[3px] border-gray-300 rounded-full group-hover:border-brand-dark group-hover:scale-125 transition-all"></div>
